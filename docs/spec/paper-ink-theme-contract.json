    { "id": "ink-action-default", "mode": "ink", "foreground": "accent-contrast", "background": "accent-primary", "minimum": 4.5, "kind": "text" },
    { "id": "ink-action-hover", "mode": "ink", "foreground": "accent-contrast-hover", "background": "accent-primary-hover", "minimum": 4.5, "kind": "text" },
    { "id": "ink-action-active", "mode": "ink", "foreground": "accent-contrast-active", "background": "accent-primary-active", "minimum": 4.5, "kind": "text" },
