    { "id": "ink-info-text", "mode": "ink", "foreground": "status-info-fg", "background": "status-info-bg", "minimum": 4.5, "kind": "text" },
    { "id": "paper-success-border", "mode": "paper", "foreground": "status-success-border", "background": "status-success-bg", "minimum": 3, "kind": "non-text" },
