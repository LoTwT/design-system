{
  "name": "@ayingott/theme",
  "version": "0.1.0",
  "description": "Ayingott CSS-first Tailwind theme package.",
  "type": "module",
  "style": "./src/index.css",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LoTwT/design-system.git",
    "directory": "packages/theme"
  },
  "files": [
    "src/**/*.css",
    "src/fonts/**/*.woff2",
    "LICENSE",
    "README.md",
    "THIRD_PARTY_NOTICES.md"
  ],
  "exports": {
    ".": "./src/index.css",
    "./index.css": "./src/index.css",
    "./fonts.css": "./src/fonts.css",
    "./fonts/*": "./src/fonts/*"
  },
  "peerDependencies": {
    "tailwindcss": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "4.2.4",
    "tailwindcss": "4.2.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT"
}
