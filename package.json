{
  "name": "design-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "check": "pnpm smoke && pnpm pack:dry && pnpm pack:consumer && pnpm site:check",
    "smoke": "node packages/theme/test/smoke.mjs",
    "pack:dry": "node packages/theme/test/pack-dry.mjs",
    "pack:consumer": "node packages/theme/test/pack-consumer.mjs",
    "site:dev": "vitepress dev site",
    "site:build": "vitepress build site && node site/test/theme-family-build.mjs",
    "site:check": "node site/test/theme-contract.mjs && node site/test/brutal-theme-contract.mjs && node site/test/cta-contrast.mjs && node site/test/experience.mjs && node site/test/theme-family.mjs",
    "site:typecheck": "vue-tsc --noEmit -p site/tsconfig.json && node site/test/typecheck-negative.mjs",
    "site:preview": "vitepress preview site",
    "site:cf-preview": "pnpm site:build && wrangler dev",
    "site:deploy": "pnpm site:build && wrangler deploy",
    "changelog": "git-cliff --unreleased --tag \"v$npm_package_version\" --strip header --prepend CHANGELOG.md",
    "prepare": "simple-git-hooks",
    "release:bump": "bumpp"
  },
  "dependencies": {
    "@ayingott/theme": "workspace:*"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm exec commitlint --edit \"$1\""
  },
  "pnpm": {
    "overrides": {
      "vitepress>vite": "6.4.3"
    }
  },
  "devDependencies": {
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "^24.12.4",
    "bumpp": "11.1.0",
    "git-cliff": "2.13.1",
    "lucide-static": "1.24.0",
    "postcss": "8.5.14",
    "simple-git-hooks": "2.13.1",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vitepress": "1.6.4",
    "vue": "3.5.33",
    "vue-tsc": "3.3.7",
    "wrangler": "4.110.0"
  }
}
