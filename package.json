{
  "name": "design-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "check": "pnpm -r check",
    "smoke": "pnpm --filter @ayingott/theme smoke",
    "pack:dry": "pnpm --filter @ayingott/theme pack:dry",
    "site:dev": "vitepress dev site",
    "site:build": "vitepress build site",
    "site:preview": "vitepress preview site",
    "site:cf-preview": "pnpm site:build && wrangler dev",
    "site:deploy": "pnpm site:build && wrangler deploy",
    "changelog": "git-cliff --unreleased --tag \"v$npm_package_version\" --strip header --prepend CHANGELOG.md",
    "prepare": "simple-git-hooks",
    "release:bump": "bumpp"
  },
  "dependencies": {
    "@ayingott/theme": "workspace:*"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm exec commitlint --edit \"$1\""
  },
  "devDependencies": {
    "@commitlint/cli": "21.0.0",
    "@commitlint/config-conventional": "21.0.0",
    "@tailwindcss/vite": "4.2.4",
    "@types/node": "^24.12.4",
    "bumpp": "11.1.0",
    "git-cliff": "2.13.1",
    "simple-git-hooks": "2.13.1",
    "tailwindcss": "4.2.4",
    "vitepress": "1.6.4",
    "wrangler": "4.88.0"
  }
}
